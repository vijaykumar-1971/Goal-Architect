<script>
const firebaseConfig = {
  apiKey:            "YOUR_API_KEY",
  authDomain:        "YOUR_PROJECT_ID.firebaseapp.com",
  projectId:         "YOUR_PROJECT_ID",
  storageBucket:     "YOUR_PROJECT_ID.appspot.com",
  messagingSenderId: "YOUR_SENDER_ID",
  appId:             "YOUR_APP_ID"
};
</script>
<!-- ══════════════════════════════════════════════════════ -->

<script>
// ── Bootstrap Firebase ────────────────────────────────
firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();
const db   = firebase.firestore();
const gp   = new firebase.auth.GoogleAuthProvider();

// ── App State ─────────────────────────────────────────
const S = {
  user:          null,
  goals:         [],
  entries:       {},        // goalId → []
  view:          'home',
  goalId:        null,
  filterGoals:   'all',
  editGoalId:    null,
  ciGoalId:      null,
};

// ── Auth ──────────────────────────────────────────────
auth.onAuthStateChanged(u => {
  document.getElementById('loading').style.display = 'none';
  if (u) {
    S.user = u;
    show('view-auth', false);
    show('app', true);
    initApp();
  } else {
    show('view-auth', true);
    show('app', false);
  }
});

function signInWithGoogle() {
  auth.signInWithPopup(gp).catch(() => toast('Sign-in failed — try again.'));
}
function signOut() { auth.signOut(); }

// ── Init ──────────────────────────────────────────────
function initApp() {
  setGreeting();
  db.collection('users').doc(S.user.uid).collection('goals')
    .orderBy('createdAt', 'desc')
    .onSnapshot(snap => {
      S.goals = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      renderCurrent();
    }, err => console.error('Firestore error', err));
  navigate('home');
}

function setGreeting() {
  const h   = new Date().getHours();
  const tod = h < 12 ? 'morning' : h < 17 ? 'afternoon' : 'evening';
  document.getElementById('time-of-day').textContent = tod;
  document.getElementById('user-first-name').textContent =
    S.user.displayName?.split(' ')[0] || 'Steward';
  document.getElementById('today-date').textContent =
    new Date().toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' });
}

// ── Firestore helpers ─────────────────────────────────
const goalsCol  = () => db.collection('users').doc(S.user.uid).collection('goals');
const entriesCol = () => db.collection('users').doc(S.user.uid).collection('entries');
const TS = () => firebase.firestore.FieldValue.serverTimestamp();

async function createGoal(data) {
  return goalsCol().add({ ...data, status:'active', entryCount:0,
    createdAt: TS(), lastUpdated: TS(), userId: S.user.uid });
}
async function updateGoal(id, data) {
  return goalsCol().doc(id).update({ ...data, lastUpdated: TS() });
}
async function addEntry(data) {
  await entriesCol().add({ ...data, createdAt: TS(), userId: S.user.uid });
  await goalsCol().doc(data.goalId).update({
    lastUpdated: TS(),
    entryCount: firebase.firestore.FieldValue.increment(1)
  });
}
async function fetchEntries(goalId) {
  const snap = await entriesCol()
    .where('goalId','==', goalId)
    .orderBy('createdAt','desc')
    .get();
  S.entries[goalId] = snap.docs.map(d => ({ id:d.id, ...d.data() }));
}

// ── Vitality logic ────────────────────────────────────
const FREQ_DAYS = { weekly:7, biweekly:14, monthly:30, quarterly:90 };

function vitality(goal) {
  if (!goal.lastUpdated) return { level:'dormant', label:'DORMANT', pct:10 };
  const ms      = goal.lastUpdated.toMillis?.() ?? Date.now();
  const days    = (Date.now() - ms) / 86400000;
  const target  = FREQ_DAYS[goal.checkInFrequency] || 30;
  const ratio   = days / target;
  if (ratio <= 0.5) return { level:'thriving',    label:'THRIVING',    pct:100 };
  if (ratio <= 1)   return { level:'active',      label:'ACTIVE',      pct:75  };
  if (ratio <= 2)   return { level:'drifting',    label:'DRIFTING',    pct:38  };
                    return { level:'dormant',      label:'DORMANT',     pct:12  };
}

function vitalityRing(v) {
  const R    = 17.5;
  const circ = 2 * Math.PI * R;
  const dash = (v.pct / 100) * circ;
  return `<div class="vr-wrap vr-${v.level}">
    <svg viewBox="0 0 46 46">
      <circle class="vr-track" cx="23" cy="23" r="${R}"/>
      <circle class="vr-arc" cx="23" cy="23" r="${R}"
        stroke-dasharray="${dash.toFixed(2)} ${circ.toFixed(2)}" stroke-dashoffset="0"/>
    </svg>
    <div class="vr-label">${v.pct}%</div>
  </div>`;
}

// ── Goal Card ─────────────────────────────────────────
function goalCard(goal) {
  if (goal.status === 'archived') return '';
  const v    = vitality(goal);
  const ms   = goal.lastUpdated?.toMillis?.() ?? 0;
  const last = ms ? timeAgo(ms) : 'Never updated';
  const completed = goal.status === 'completed';
  return `<div class="goal-card" onclick="navigate('goal',{goalId:'${goal.id}'})">
    <div class="gc-head">
      ${vitalityRing(v)}
      <div class="gc-info">
        <div class="gc-title">${esc(goal.title)}</div>
        <div class="gc-badges">
          <span class="badge badge-cat">${esc(goal.category||'Goal')}</span>
          <span class="badge">${esc(goal.horizon||'—')}</span>
          ${completed ? '<span class="badge" style="color:var(--green);border-color:rgba(74,222,128,.3)">✓ Done</span>' : ''}
        </div>
      </div>
    </div>
    <p class="gc-desc">${esc(goal.description||'')}</p>
    <div class="gc-foot">
      <div class="gc-status">
        <span class="status-dot bg-${v.level}"></span>
        <span class="text-${v.level}" style="font-size:12px;font-weight:600;">${v.label}</span>
      </div>
      <div class="gc-updated">Updated ${last}</div>
    </div>
  </div>`;
}

// ── Navigation ────────────────────────────────────────
function navigate(view, params = {}) {
  document.querySelectorAll('.view').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('.nav-tab').forEach(el => el.classList.remove('active'));
  S.view   = view;
  S.goalId = params.goalId || null;
  const vEl = document.getElementById('view-' + view);
  if (vEl) vEl.classList.remove('hidden');
  const tab = document.querySelector(`.nav-tab[data-view="${view}"]`);
  if (tab) tab.classList.add('active');
  const fab = document.getElementById('fab');
  const showFab = ['home','goals'].includes(view);
  fab.style.display = showFab ? 'flex' : 'none';
  switch (view) {
    case 'home':     renderHome();              break;
    case 'goals':    renderGoals();             break;
    case 'goal':     renderDetail(params.goalId); break;
    case 'insights': renderInsights();          break;
    case 'profile':  renderProfile();           break;
  }
}

function renderCurrent() {
  if (S.view === 'home')     renderHome();
  else if (S.view === 'goals')    renderGoals();
  else if (S.view === 'insights') renderInsights();
  else if (S.view === 'profile')  renderProfile();
}

// ── Home ──────────────────────────────────────────────
function renderHome() {
  const active   = S.goals.filter(g => g.status === 'active');
  const neglected = active.filter(g => ['drifting','dormant'].includes(vitality(g).level));
  const thriving  = active.filter(g => vitality(g).level === 'thriving');

  setText('stat-active',    active.length);
  setText('stat-attention', neglected.length);
  setText('stat-healthy',   thriving.length);

  const banner = document.getElementById('home-attention-banner');
  if (neglected.length) {
    banner.innerHTML = `<div class="attention-card">
      <div class="ac-ico">🌿</div>
      <div>
        <strong>${neglected.length} goal${neglected.length > 1 ? 's' : ''} need${neglected.length === 1 ? 's' : ''} tending</strong>
        <p>These haven't been updated recently. A quick check-in keeps momentum alive.</p>
      </div>
    </div>`;
  } else {
    banner.innerHTML = '';
  }

  const list = document.getElementById('home-goals-list');
  if (!active.length) {
    list.innerHTML = `<div class="empty-state">
      <div class="es-icon">🌱</div>
      <h3>Plant your first goal</h3>
      <p>Tap <strong>+</strong> to add a long-term goal you want to steward over time.</p>
    </div>`;
    return;
  }

  const order = { dormant:0, drifting:1, active:2, thriving:3 };
  const sorted = [...active].sort((a,b) => order[vitality(a).level] - order[vitality(b).level]);
  const badOnes  = sorted.filter(g => ['drifting','dormant'].includes(vitality(g).level));
  const goodOnes = sorted.filter(g => !['drifting','dormant'].includes(vitality(g).level));

  let html = '';
  if (badOnes.length) {
    html += '<div class="section-label">Needs Tending</div>';
    badOnes.forEach(g => html += goalCard(g));
  }
  if (goodOnes.length) {
    html += '<div class="section-label">On Track</div>';
    goodOnes.forEach(g => html += goalCard(g));
  }
  list.innerHTML = html;
}

// ── Goals List ────────────────────────────────────────
function renderGoals() {
  const f = S.filterGoals;
  let goals = S.goals.filter(g => g.status !== 'archived');
  if (f !== 'all') goals = goals.filter(g => g.status === f);

  const content = document.getElementById('goals-list-content');
  if (!goals.length) {
    content.innerHTML = `<div class="empty-state">
      <div class="es-icon">${f==='completed'?'🏆':f==='paused'?'⏸️':'🌱'}</div>
      <h3>${f==='all'?'No goals yet':`No ${f} goals`}</h3>
      <p>${f==='all'?'Tap + to create your first long-term goal.':
         `Goals marked as ${f} will appear here.`}</p>
    </div>`;
    return;
  }
  content.innerHTML = goals.map(goalCard).join('');

  // re-bind filter chips
  document.querySelectorAll('#goals-filter-row .filter-chip').forEach(chip => {
    chip.onclick = () => {
      S.filterGoals = chip.dataset.filter;
      document.querySelectorAll('#goals-filter-row .filter-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      renderGoals();
    };
  });
}

// ── Goal Detail ───────────────────────────────────────
async function renderDetail(goalId) {
  const goal = S.goals.find(g => g.id === goalId);
  if (!goal) { navigate('goals'); return; }

  const v = vitality(goal);
  const vitalColor = { thriving:'var(--green)', active:'var(--accent)', drifting:'var(--amber)', dormant:'var(--red)' };
  const typeColors  = { 'check-in':'var(--accent)', refinement:'var(--amber)', milestone:'var(--green)', reflection:'var(--text-2)' };

  setText('detail-title', goal.title);
  setText('detail-desc',  goal.description || '');

  document.getElementById('detail-meta').innerHTML = `
    <span class="badge badge-cat">${esc(goal.category||'—')}</span>
    <span class="badge">${esc(goal.horizon||'—')}</span>
    <span class="badge" style="color:${vitalColor[v.level]};border-color:${vitalColor[v.level]}44;background:${vitalColor[v.level]}11;">${v.label}</span>
    ${goal.status !== 'active' ? `<span class="badge" style="color:var(--text-3)">${cap(goal.status)}</span>` : ''}
  `;

  // Action buttons
  const isActive  = goal.status === 'active';
  const isPaused  = goal.status === 'paused';
  const isDone    = goal.status === 'completed';
  document.getElementById('detail-btns').innerHTML = `
    ${!isDone ? `<button class="btn-primary" onclick="showCI('${goalId}')">+ Stewardship Entry</button>` : ''}
    <button class="btn-outline" onclick="showGoalModal('${goalId}')">Edit</button>
    ${isActive  ? `<button class="btn-outline btn-amber" onclick="setStatus('${goalId}','paused')">Pause</button>` : ''}
    ${isPaused  ? `<button class="btn-outline btn-success" onclick="setStatus('${goalId}','active')">Resume</button>` : ''}
    ${!isDone   ? `<button class="btn-outline btn-success" onclick="setStatus('${goalId}','completed')">Complete ✓</button>` : ''}
  `;

  // Stats strip
  const created = goal.createdAt?.toDate?.() || new Date();
  const days    = Math.max(0, Math.floor((Date.now() - created.getTime()) / 86400000));
  document.getElementById('detail-stats').innerHTML = `
    <div class="dstat"><div class="dstat-val">${goal.entryCount||0}</div><div class="dstat-label">Entries</div></div>
    <div class="dstat"><div class="dstat-val">${days}</div><div class="dstat-label">Days Old</div></div>
    <div class="dstat"><div class="dstat-val text-${v.level}">${v.pct}%</div><div class="dstat-label">Vitality</div></div>
  `;

  // Timeline
  const tl = document.getElementById('goal-timeline');
  tl.innerHTML = '<div style="padding:24px;text-align:center;color:var(--text-3);font-size:13px;">Loading…</div>';

  await fetchEntries(goalId);
  const entries = S.entries[goalId] || [];

  if (!entries.length) {
    tl.innerHTML = `<div class="empty-state" style="padding:36px 20px;">
      <div class="es-icon">📝</div>
      <h3>No entries yet</h3>
      <p>Tap "Stewardship Entry" to start logging progress, reflections, and milestones.</p>
    </div>`;
    return;
  }

  const typeEmoji = { 'check-in':'✅', refinement:'✏️', milestone:'🏆', reflection:'💭' };
  const moodEmoji = { stuck:'😔', progressing:'⚡', thriving:'🌱' };

  tl.innerHTML = '<div class="section-label">Stewardship Log</div>' +
    entries.map(e => {
      const tc   = typeColors[e.type] || 'var(--text-2)';
      const date = e.createdAt?.toDate ? fmtDate(e.createdAt.toDate()) : '—';
      return `<div class="tl-item">
        <div class="tl-left">
          <div class="tl-dot">${typeEmoji[e.type]||'📌'}</div>
          <div class="tl-line"></div>
        </div>
        <div class="tl-body">
          <div class="tl-head">
            <span class="tl-type" style="color:${tc}">${cap(e.type||'entry')}</span>
            <span class="tl-date">${date}</span>
          </div>
          <p class="tl-text">${esc(e.content||'')}</p>
          ${e.mood ? `<div class="tl-mood">${moodEmoji[e.mood]||''} ${cap(e.mood)}</div>` : ''}
        </div>
      </div>`;
    }).join('');
}

// ── Insights ──────────────────────────────────────────
function renderInsights() {
  const active    = S.goals.filter(g => g.status === 'active');
  const completed = S.goals.filter(g => g.status === 'completed');
  const total     = S.goals.filter(g => g.status !== 'archived');

  const totalEntries = S.goals.reduce((n, g) => n + (g.entryCount||0), 0);

  const byCat = {};
  total.forEach(g => { const c = g.category||'Other'; byCat[c] = (byCat[c]||0)+1; });
  const catList = Object.entries(byCat).sort((a,b)=>b[1]-a[1]);

  const vMap = { thriving:0, active:0, drifting:0, dormant:0 };
  active.forEach(g => vMap[vitality(g).level]++);

  const vitBars = [
    { label:'Thriving',  count:vMap.thriving,    color:'var(--green)'  },
    { label:'Active',    count:vMap.active,       color:'var(--accent)' },
    { label:'Drifting',  count:vMap.drifting,     color:'var(--amber)'  },
    { label:'Dormant',   count:vMap.dormant,       color:'var(--red)'    },
  ].map(b => {
    const pct = active.length ? Math.round(b.count/active.length*100) : 0;
    return `<div class="vit-bar-row">
      <div class="vit-bar-meta"><span>${b.label}</span><span>${b.count} (${pct}%)</span></div>
      <div class="vit-bar-bg"><div class="vit-bar-fill" style="width:${pct}%;background:${b.color};"></div></div>
    </div>`;
  }).join('');

  const content = document.getElementById('insights-content');
  content.innerHTML = `
    <div class="stats-row" style="grid-template-columns:repeat(2,1fr);">
      <div class="stat-card"><div class="stat-num text-active">${totalEntries}</div><div class="stat-label">Total Entries</div></div>
      <div class="stat-card"><div class="stat-num text-thriving">${completed.length}</div><div class="stat-label">Completed</div></div>
    </div>

    <div class="section-label">Goal Vitality</div>
    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r-md);padding:18px;margin-bottom:8px;">
      ${active.length ? vitBars : '<p style="font-size:13px;color:var(--text-3);">No active goals yet.</p>'}
    </div>

    ${catList.length ? `
    <div class="section-label">By Category</div>
    <div class="list-card">
      ${catList.map(([c,n]) => `
        <div class="list-row">
          <span>${c}</span>
          <span class="badge badge-cat">${n}</span>
        </div>`).join('')}
    </div>` : ''}

    <div class="section-label">Time Horizons</div>
    <div class="list-card">
      ${(() => {
        const horizons = {};
        total.forEach(g => { const h = g.horizon||'—'; horizons[h] = (horizons[h]||0)+1; });
        const hl = Object.entries(horizons).sort((a,b)=>b[1]-a[1]);
        return hl.length ? hl.map(([h,n]) =>
          `<div class="list-row"><span>${h}</span><span class="badge">${n}</span></div>`
        ).join('') : '<div class="list-row" style="color:var(--text-3);">No data yet</div>';
      })()}
    </div>
  `;
}

// ── Profile ───────────────────────────────────────────
function renderProfile() {
  const u  = S.user;
  const na = S.goals.filter(g=>g.status==='active').length;
  const nc = S.goals.filter(g=>g.status==='completed').length;
  const np = S.goals.filter(g=>g.status==='paused').length;
  document.getElementById('profile-content').innerHTML = `
    <div class="profile-card">
      ${u.photoURL ? `<img class="profile-avatar" src="${u.photoURL}" referrerpolicy="no-referrer" />` : '<div class="profile-avatar" style="background:var(--accent-d);display:flex;align-items:center;justify-content:center;font-size:20px;color:#0b0e13;">👤</div>'}
      <div>
        <div class="profile-name">${esc(u.displayName||'Steward')}</div>
        <div class="profile-email">${esc(u.email||'')}</div>
      </div>
    </div>

    <div class="section-label">Your Goals</div>
    <div class="list-card">
      <div class="list-row"><span>Active</span><span class="badge badge-cat">${na}</span></div>
      <div class="list-row"><span>Completed</span><span class="badge" style="color:var(--green)">${nc}</span></div>
      <div class="list-row"><span>Paused</span><span class="badge">${np}</span></div>
    </div>

    <div class="section-label">About Goal Steward</div>
    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r-md);padding:18px;margin-bottom:12px;">
      <p style="font-size:13px;color:var(--text-2);line-height:1.75;">Goal Steward is built around one idea: the things that matter most over years rarely survive without intentional tending. This app gives you a home for long-term initiatives so they don't get buried under daily urgency. Each goal has a <strong>Vitality Ring</strong> — a living indicator of whether you're nurturing it at the pace you intended.</p>
    </div>

    <div class="section-label">Check-in Guide</div>
    <div class="list-card">
      <div class="list-row" style="flex-direction:column;align-items:flex-start;gap:4px;">
        <strong style="font-size:13px;">✅ Check-in</strong>
        <span style="font-size:12px;color:var(--text-2);">Routine status update — what's happened since last time?</span>
      </div>
      <div class="list-row" style="flex-direction:column;align-items:flex-start;gap:4px;">
        <strong style="font-size:13px;">✏️ Refinement</strong>
        <span style="font-size:12px;color:var(--text-2);">Evolving the goal's direction, scope, or definition of success.</span>
      </div>
      <div class="list-row" style="flex-direction:column;align-items:flex-start;gap:4px;">
        <strong style="font-size:13px;">🏆 Milestone</strong>
        <span style="font-size:12px;color:var(--text-2);">A significant achievement or phase completed.</span>
      </div>
      <div class="list-row" style="flex-direction:column;align-items:flex-start;gap:4px;">
        <strong style="font-size:13px;">💭 Reflection</strong>
        <span style="font-size:12px;color:var(--text-2);">Deeper thinking: learnings, blockers, or renewed commitment.</span>
      </div>
    </div>

    <button class="btn-signout" onclick="signOut()">Sign Out</button>
    <div style="height:20px;"></div>
  `;
}

// ── Goal Modal ────────────────────────────────────────
function showGoalModal(goalId = null) {
  S.editGoalId = goalId;
  document.getElementById('gm-modal-title').textContent = goalId ? 'Edit Goal' : 'New Goal';

  const freq = goalId ? (S.goals.find(g=>g.id===goalId)?.checkInFrequency || 'monthly') : 'biweekly';

  if (goalId) {
    const g = S.goals.find(g => g.id === goalId);
    if (!g) return;
    document.getElementById('gm-title').value    = g.title || '';
    document.getElementById('gm-desc').value     = g.description || '';
    document.getElementById('gm-category').value = g.category || 'Career';
    document.getElementById('gm-horizon').value  = g.horizon || '1–2 years';
  } else {
    document.getElementById('gm-title').value    = '';
    document.getElementById('gm-desc').value     = '';
    document.getElementById('gm-category').value = 'Career';
    document.getElementById('gm-horizon').value  = '1–2 years';
  }

  document.querySelectorAll('#gm-freq-chips .chip').forEach(c =>
    c.classList.toggle('selected', c.dataset.val === freq));

  showModal('modal-goal-overlay');
}

async function saveGoal() {
  const title = document.getElementById('gm-title').value.trim();
  const desc  = document.getElementById('gm-desc').value.trim();
  if (!title) { toast('Please add a goal title.'); return; }
  if (!desc)  { toast('Please describe the goal.'); return; }

  const data = {
    title,
    description:       desc,
    category:          document.getElementById('gm-category').value,
    horizon:           document.getElementById('gm-horizon').value,
    checkInFrequency:  chipVal('gm-freq-chips') || 'biweekly',
  };

  try {
    if (S.editGoalId) {
      await updateGoal(S.editGoalId, data);
      toast('Goal updated ✓');
    } else {
      await createGoal(data);
      toast('Goal created 🌱');
    }
    hideModal('modal-goal-overlay');
  } catch (e) {
    toast('Error saving — check your connection.');
    console.error(e);
  }
}

// ── Check-in Modal ────────────────────────────────────
function showCI(goalId) {
  S.ciGoalId = goalId;
  const g = S.goals.find(g => g.id === goalId);
  document.getElementById('ci-goal-name').textContent = g?.title || '—';
  document.getElementById('ci-content').value = '';
  document.querySelectorAll('#ci-type-chips .chip').forEach(c =>
    c.classList.toggle('selected', c.dataset.val === 'check-in'));
  document.querySelectorAll('#ci-mood-chips .chip').forEach(c =>
    c.classList.toggle('selected', c.dataset.val === 'progressing'));
  showModal('modal-ci-overlay');
}

async function saveEntry() {
  const content = document.getElementById('ci-content').value.trim();
  if (!content) { toast('Please add some notes.'); return; }

  try {
    await addEntry({
      goalId:  S.ciGoalId,
      content,
      type:    chipVal('ci-type-chips') || 'check-in',
      mood:    chipVal('ci-mood-chips') || 'progressing',
    });
    toast('Entry saved ✓');
    hideModal('modal-ci-overlay');
    if (S.view === 'goal' && S.goalId === S.ciGoalId) {
      renderDetail(S.goalId);
    }
  } catch (e) {
    toast('Error saving — check your connection.');
    console.error(e);
  }
}

// ── Status change ─────────────────────────────────────
async function setStatus(goalId, status) {
  try {
    await goalsCol().doc(goalId).update({ status });
    const labels = { completed:'Completed 🏆', paused:'Goal paused ⏸', active:'Goal resumed ✓' };
    toast(labels[status] || 'Updated');
    if (S.view === 'goal') renderDetail(goalId);
  } catch (e) { toast('Error updating.'); }
}

// ── UI helpers ────────────────────────────────────────
function pickChip(el, gid) {
  document.querySelectorAll(`#${gid} .chip`).forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
}
function chipVal(gid) {
  return document.querySelector(`#${gid} .chip.selected`)?.dataset.val || null;
}
function showModal(id) { document.getElementById(id).classList.remove('hidden'); }
function hideModal(id) { document.getElementById(id).classList.add('hidden'); }
function closeOnOverlay(e, id) { if (e.target.id === id) hideModal(id); }

function show(id, visible) {
  document.getElementById(id).classList.toggle('hidden', !visible);
}
function setText(id, val) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

let toastT;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastT);
  toastT = setTimeout(() => el.classList.remove('show'), 2600);
}

function esc(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function cap(s) { return s ? s[0].toUpperCase() + s.slice(1) : ''; }
function timeAgo(ms) {
  const d = Math.floor((Date.now() - ms) / 86400000);
  if (d === 0)  return 'today';
  if (d === 1)  return 'yesterday';
  if (d < 7)   return `${d} days ago`;
  if (d < 30)  return `${Math.floor(d/7)}w ago`;
  if (d < 365) return `${Math.floor(d/30)}mo ago`;
  return `${Math.floor(d/365)}y ago`;
}
function fmtDate(d) {
  return d.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
}
